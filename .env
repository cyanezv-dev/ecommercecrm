# Desarrollo: el navegador llama a /api y Vite reenvía al backend Leadflow (puerto 3001).
# Ahí es donde vive la conexión a PostgreSQL (DATABASE_URL en backend/.env).
VITE_API_PROXY_TARGET=http://localhost:3001

# No pongas VITE_API_URL apuntando a localhost:3001 aquí: rompe CORS o el proxy.
# Para producción (build en DigitalOcean), sí: VITE_API_URL=https://tu-api-publica.com/api

